@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="user-layout">

    <!-- SIDEBAR -->
    <aside class="user-sidebar @(IsCollapsed ? "collapsed" : "")">

        <!-- HEADER -->
        <div class="sidebar-header">
            <div class="logo" @onclick="GoHome">
                <span class="logo-text">@Tenant.StoreName</span>
            </div>
            <button class="collapse-btn" @onclick="ToggleSidebar">
                <i class="fa fa-bars"></i>
            </button>
        </div>

        <!-- MENU -->
        <nav class="sidebar-menu">

            <NavLink class="menu-item" href="/account/profile" Match="NavLinkMatch.All">
                <i class="fa fa-user"></i>
                <span>Profile</span>
            </NavLink>

            <NavLink class="menu-item" href="/account/orders">
                <i class="fa fa-box"></i>
                <span>Orders</span>
            </NavLink>

            <NavLink class="menu-item" href="/account/addresses">
                <i class="fa fa-map-marker-alt"></i>
                <span>Addresses</span>
            </NavLink>

            @if (_isInfluencer)
            {
                <NavLink class="menu-item" href="/account/coupons">
                    <i class="fa fa-tag"></i>
                    <span>My Coupons</span>
                </NavLink>

                <NavLink class="menu-item" href="/account/stats">
                    <i class="fa fa-chart-bar"></i>
                    <span>Stats & Payouts</span>
                </NavLink>
            }

        </nav>

        <!-- FOOTER -->
        <div class="sidebar-footer">

            <NavLink class="menu-item store-link" href="/">
                <i class="fa fa-store"></i>
                <span>Store</span>
            </NavLink>

            <NavLink class="menu-item logout" href="authentication/logout">
                <i class="fa fa-sign-out-alt"></i>
                <span>Logout</span>
            </NavLink>

        </div>

    </aside>

    <!-- CONTENT -->
    <main class="user-content @(IsCollapsed ? "collapsed" : "")">
        @Body
    </main>


</div>

@code {
    private bool IsCollapsed;
    private bool _isInfluencer;

    [CascadingParameter]
    private Task<AuthenticationState> AuthState { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState;
        _isInfluencer = state.User.IsInRole("Influencer");
    }

    private void ToggleSidebar()
        => IsCollapsed = !IsCollapsed;

    private void GoHome()
        => Nav.NavigateTo("/");
}