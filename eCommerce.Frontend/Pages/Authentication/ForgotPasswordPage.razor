@page "/authentication/forgot-password"
@layout Auth
@attribute [AllowAnonymous]
@using eCommerce.Frontend.Components.Base

<div class="login-page beauty">
    <div class="login-card">

        @if (_sent)
        {
            <div style="text-align:center">
                <div style="font-size:2.5rem;margin-bottom:12px">✉</div>
                <h2 class="login-title">@L.Get("check_your_email")</h2>
                <p style="color:#666;margin-bottom:24px">@L.Get("reset_link_sent_msg")</p>
                <a href="/authentication/login" class="btn btn-dark w-100">@L.Get("back_to_login")</a>
            </div>
        }
        else
        {
            <h2 class="login-title">@L.Get("forgot_password")</h2>
            <p style="color:#888;font-size:14px;margin-bottom:20px">@L.Get("forgot_password_prompt")</p>

            <GlobalError Error="@_error" />

            <EditForm Model="_model" OnValidSubmit="Submit">
                <DataAnnotationsValidator />

                <AppInput @bind-Value="_model.Email" Label="@L.Get("email_address")" />

                <button class="btn btn-dark w-100 mt-3" type="submit" disabled="@_isLoading">
                    @(_isLoading ? L.Get("loading") : L.Get("send_reset_link"))
                </button>

                <div class="text-center mt-3" style="font-size:13px;color:#aaa;">
                    <a href="/authentication/login">@L.Get("back_to_login")</a>
                </div>
            </EditForm>
        }

    </div>
</div>

@code {
    readonly ForgotPasswordDTO _model = new();
    bool _isLoading;
    bool _sent;
    string _error = string.Empty;

    async Task Submit()
    {
        _isLoading = true;
        _error = string.Empty;

        var result = await authService.ForgotPassword(_model);

        _isLoading = false;

        if (result.Success)
            _sent = true;
        else
            _error = result.Message ?? L.Get("something_wrong");
    }
}
