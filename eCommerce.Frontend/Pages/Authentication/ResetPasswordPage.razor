@page "/authentication/reset-password"
@layout Auth
@attribute [AllowAnonymous]
@using eCommerce.Frontend.Components.Base

<div class="login-page beauty">
    <div class="login-card">

        @if (_done)
        {
            <div style="text-align:center">
                <div style="font-size:2.5rem;margin-bottom:12px">✓</div>
                <h2 class="login-title">@L.Get("password_reset_success")</h2>
                <p style="color:#666;margin-bottom:24px">@L.Get("password_reset_success_msg")</p>
                <a href="/authentication/login" class="btn btn-dark w-100">@L.Get("login")</a>
            </div>
        }
        else if (_invalidLink)
        {
            <div style="text-align:center">
                <h2 class="login-title">@L.Get("invalid_link_title")</h2>
                <p style="color:#888;margin-bottom:24px">@L.Get("invalid_link")</p>
                <a href="/authentication/forgot-password" class="btn btn-dark w-100">@L.Get("try_again")</a>
            </div>
        }
        else
        {
            <h2 class="login-title">@L.Get("reset_password")</h2>

            <GlobalError Error="@_error" />

            <EditForm Model="_model" OnValidSubmit="Submit">
                <DataAnnotationsValidator />

                <AppInput @bind-Value="_model.NewPassword" Label="@L.Get("new_password")" Type="password" />

                @if (!string.IsNullOrEmpty(_model.NewPassword))
                {
                    <div class="pw-rules">
                        <div class="pw-rule @(Rule_MinLength ? "pw-rule--pass" : "pw-rule--fail")">
                            <i class="fa @(Rule_MinLength ? "fa-check" : "fa-xmark")"></i>
                            At least 8 characters
                        </div>
                        <div class="pw-rule @(Rule_Uppercase ? "pw-rule--pass" : "pw-rule--fail")">
                            <i class="fa @(Rule_Uppercase ? "fa-check" : "fa-xmark")"></i>
                            One uppercase letter (A–Z)
                        </div>
                        <div class="pw-rule @(Rule_Lowercase ? "pw-rule--pass" : "pw-rule--fail")">
                            <i class="fa @(Rule_Lowercase ? "fa-check" : "fa-xmark")"></i>
                            One lowercase letter (a–z)
                        </div>
                        <div class="pw-rule @(Rule_Digit ? "pw-rule--pass" : "pw-rule--fail")">
                            <i class="fa @(Rule_Digit ? "fa-check" : "fa-xmark")"></i>
                            One number (0–9)
                        </div>
                        <div class="pw-rule @(Rule_Special ? "pw-rule--pass" : "pw-rule--fail")">
                            <i class="fa @(Rule_Special ? "fa-check" : "fa-xmark")"></i>
                            One special character (!@@#$…)
                        </div>
                    </div>
                }

                <AppInput @bind-Value="_confirmPassword" Label="@L.Get("confirm_password")" Type="password" />

                <button class="btn btn-dark w-100 mt-3" type="submit" disabled="@_isLoading">
                    @(_isLoading ? L.Get("loading") : L.Get("reset_password"))
                </button>
            </EditForm>
        }

    </div>
</div>

@code {
    readonly ResetPasswordDTO _model = new();
    string _confirmPassword = string.Empty;
    bool _isLoading;
    bool _done;
    bool _invalidLink;
    string _error = string.Empty;

    bool Rule_MinLength => (_model.NewPassword?.Length ?? 0) >= 8;
    bool Rule_Uppercase => _model.NewPassword?.Any(char.IsUpper) == true;
    bool Rule_Lowercase => _model.NewPassword?.Any(char.IsLower) == true;
    bool Rule_Digit     => _model.NewPassword?.Any(char.IsDigit) == true;
    bool Rule_Special   => _model.NewPassword?.Any(c => !char.IsLetterOrDigit(c) && c != '_') == true;

    protected override void OnInitialized()
    {
        var uri = new Uri(NavManager.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        _model.UserId = query["userId"] ?? string.Empty;
        _model.Token  = query["token"]  ?? string.Empty;

        if (string.IsNullOrWhiteSpace(_model.UserId) || string.IsNullOrWhiteSpace(_model.Token))
            _invalidLink = true;
    }

    async Task Submit()
    {
        if (_model.NewPassword != _confirmPassword)
        {
            _error = L.Get("passwords_dont_match");
            return;
        }

        _isLoading = true;
        _error = string.Empty;

        var result = await authService.ResetPassword(_model);

        _isLoading = false;

        if (result.Success)
            _done = true;
        else
            _error = result.Message ?? L.Get("something_wrong");
    }
}
